    "//third_party/stator/crates/stator_jse/src/platform.rs",
    "//third_party/stator/crates/stator_jse/src/zone/mod.rs",
  ]

  # Chromium's vendored copies of stator_jse's dependencies.  Adjust these
  # paths to match wherever the crates are vendored in //third_party.
  deps = [
    "//third_party/rust/bumpalo/v3:lib",
    "//third_party/rust/bitflags/v2:lib",
    "//third_party/rust/log/v0_4:lib",
    "//third_party/rust/parking_lot/v0_12:lib",
    "//third_party/rust/regress/v0_10:lib",
    "//third_party/rust/smallvec/v1:lib",
    "//third_party/rust/thiserror/v2:lib",
  ]
}

# ---------------------------------------------------------------------------
# stator — C-ABI FFI surface (stator_jse_ffi crate).  Links stator_jse and
# exposes the stable C API used by stator_bridge.
#
# The GN target is named "stator" (the public-facing engine name); the Rust
# crate is named "stator_jse_ffi" (set via crate_name below) to match the Cargo
# workspace.
# ---------------------------------------------------------------------------
rust_library("stator") {
  crate_name = "stator_jse_ffi"
  crate_root = "//third_party/stator/crates/stator_jse_ffi/src/lib.rs"
  edition = "2024"

  sources = [
    "//third_party/stator/crates/stator_jse_ffi/src/lib.rs",
  ]

  deps = [
    ":stator_jse",
    "//third_party/rust/log/v0_4:lib",
  ]

  # stator_jse_ffi contains unsafe blocks required by the C FFI boundary.
  allow_unsafe = true
}

# ---------------------------------------------------------------------------
# stator_bridge — C++17 shim that exposes the v8:: namespace over stator.h.
#
# Consumers add this to deps instead of "//v8" when js_engine = "stator".
# The public include path exposes both stator.h and v8_compat.h.
# ---------------------------------------------------------------------------
source_set("stator_bridge") {
  sources = [ "stator_bridge.cc" ]

  public_configs = [ ":stator_bridge_include" ]

  deps = [ ":stator" ]
}

config("stator_bridge_include") {
  include_dirs = [ "//third_party/stator/crates/stator_jse_ffi/include" ]
}
