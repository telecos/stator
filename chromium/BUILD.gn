    "//third_party/stator/crates/stator_jse/src/interpreter/mod.rs",
    "//third_party/stator/crates/stator_jse/src/lib.rs",
    "//third_party/stator/crates/stator_jse/src/objects/heap_object.rs",
    "//third_party/stator/crates/stator_jse/src/objects/js_array.rs",
    "//third_party/stator/crates/stator_jse/src/objects/js_function.rs",
    "//third_party/stator/crates/stator_jse/src/objects/js_object.rs",
    "//third_party/stator/crates/stator_jse/src/objects/map.rs",
    "//third_party/stator/crates/stator_jse/src/objects/mod.rs",
    "//third_party/stator/crates/stator_jse/src/objects/regexp.rs",
