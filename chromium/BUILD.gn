# chromium/BUILD.gn — GN build integration for the Stator JavaScript engine.
#
# This file is intended to be placed (or symlinked) inside a Chromium source
# checkout so that Stator can be used as a drop-in replacement for V8 when
# building with `js_engine = "stator"`.
#
# Assumed vendoring location inside a Chromium checkout:
#
#   //third_party/stator/                  ← stator repository root
#   //third_party/stator/chromium/         ← this directory
#
# The two targets provided here are consumed by gin/BUILD.gn:
#
#   rust_library("stator_jse")  — compiles crates/stator_jse (rlib)
#   rust_library("stator")       — compiles crates/stator_jse_ffi  (staticlib)
#   source_set("stator_bridge")  — C++17 shim: v8:: namespace over stator.h

import("//build/rust/rust_library.gni")

# ---------------------------------------------------------------------------
# stator_jse — pure Rust interpreter, bytecode compiler, GC, and builtins.
# ---------------------------------------------------------------------------
rust_library("stator_jse") {
  crate_name = "stator_jse"
  crate_root = "//third_party/stator/crates/stator_jse/src/lib.rs"
  edition = "2024"

  sources = [
    "//third_party/stator/crates/stator_jse/src/builtins/array.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/error.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/global.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/iterator.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/json.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/map.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/math.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/mod.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/number.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/object.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/promise.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/proxy.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/reflect.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/set.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/string.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/util.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/weak_map.rs",
    "//third_party/stator/crates/stator_jse/src/builtins/weak_set.rs",
    "//third_party/stator/crates/stator_jse/src/bytecode/bytecode_array.rs",
    "//third_party/stator/crates/stator_jse/src/bytecode/bytecode_generator.rs",
    "//third_party/stator/crates/stator_jse/src/bytecode/bytecodes.rs",
    "//third_party/stator/crates/stator_jse/src/bytecode/feedback.rs",
    "//third_party/stator/crates/stator_jse/src/bytecode/mod.rs",
    "//third_party/stator/crates/stator_jse/src/bytecode/register.rs",
    "//third_party/stator/crates/stator_jse/src/bytecode/source_positions.rs",
    "//third_party/stator/crates/stator_jse/src/compiler/baseline/compiler.rs",
    "//third_party/stator/crates/stator_jse/src/compiler/baseline/masm_x64.rs",
    "//third_party/stator/crates/stator_jse/src/compiler/baseline/mod.rs",
    "//third_party/stator/crates/stator_jse/src/compiler/mod.rs",
    "//third_party/stator/crates/stator_jse/src/error.rs",
    "//third_party/stator/crates/stator_jse/src/gc/handle.rs",
    "//third_party/stator/crates/stator_jse/src/gc/heap.rs",
    "//third_party/stator/crates/stator_jse/src/gc/mark_sweep_compact.rs",
    "//third_party/stator/crates/stator_jse/src/gc/mod.rs",
    "//third_party/stator/crates/stator_jse/src/gc/scavenger.rs",
